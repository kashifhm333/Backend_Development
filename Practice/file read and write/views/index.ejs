<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="main bg-gray-200 p-4 rounded-lg shadow-md w-1/2 mx-auto mt-10">
        <div class="form flex flex-col gap-4">
            <form action="/create" method="post" class="flex flex-col border-2">
                <input type="text" name="title" placeholder="Enter The Title" class="border-2 rounded-lg p-2">
                <textarea name="details" placeholder="Enter The Description" class="border-2 rounded-lg p-2"></textarea>
                <input type="submit" value="Create Task" class="hover:cursor-pointer bg-blue-500">
            </form>
        </div>
        <div class="tasks">
            <% files.forEach(val=> { %>
                <div class="task p-4 border-b border-gray-600">
                    <h3 class="text-xl font-bold text-white"><%= val %> </h3>
                    <a href="/files/<%= val %>" class="text-blue-500 hover:underline">Read Me</a>
                </div>
                <% }); %>
        </div>
    </div>

</body>

</html>