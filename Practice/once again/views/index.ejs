<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

<div class="main bg-gray-200 w-full h-screen flex flex-col items-center justify-center ">
    <div class="form" class="bg-white p-6 rounded-lg shadow-md ">
        <form action="/create" class="flex flex-col gap-4">
            <input type="text" name="title" placeholder="Enter the File name" class="border border-gray-300 rounded py-2 px-4 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <textarea name="description" id="" placeholder="Enter the File description" class="border border-gray-300 rounded py-2 px-4 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
            <input type="submit" value="Create File" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
        </form>
    </div>


    <div class="tasks">
        <% files.forEach(val => { %>
            <div class="task bg-white p-4 rounded-lg shadow-md mb-4 mt-2">
                <h2><%= val %></h2>
                <div>
                    <a href="/files/<%= val %>" class="text-blue-500 hover:text-blue-700">View File</a>
                    <a href="/edit/<%= val %>" class="text-green-500 hover:text-green-700">Edit File</a>
                </div>
            </div>
        <% }); %>
    </div>


    </div>
</body>
</html>