<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Page</title>
    <script src="https://cdn.tailwindcss.com"></script>   
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white">
        <a href="/" class="text-blue-500 inline-block mb-10">go back to home</a>
   
         <div class="form p-10 text-white">
            <form action="/edit" method="POST">
                <input class="block w-1/3 rounded-lg px-5 py-2 bg-zinc-800 mt-2" type="text" placeholder="Previous Name" name="Previous" value="<%= filename%>">
                <input class="block w-1/3 rounded-lg px-5 py-2 bg-zinc-800 mt-2" type="text" placeholder="New Name" name="New">
                <input class="mt-2 bg-yellow-600 rounded-lg px-5 py-2 cursor-pointer" type="submit" value="Update Name">
            </form>
        </div>
    </div>
</body>
</html>