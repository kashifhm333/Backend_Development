<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>   
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <!-- Form Section -->
        <div class="form p-10 text-white">
            <form action="/create" method="POST">
                <input class="block w-full rounded-lg px-5 py-2 bg-zinc-800" type="text" placeholder="title goes here" name="title">
                <textarea class="block w-full rounded-lg mt-2 px-5 py-2 bg-zinc-800 resize-none" placeholder="description goes here" name="details"></textarea>
                <input class="mt-2 bg-blue-600 rounded-lg px-5 py-2 cursor-pointer" type="submit" value="Create Task">
            </form>
        </div>

        <!-- Tasks Section -->
        <div class="tasks flex p-10 gap-5 flex-wrap">
            <% files.forEach(val => { %>
                <div class="task w-72 px-3 py-4 bg-zinc-800 text-white rounded-lg">
                    <h1 class="text-white text-3xl tracking-tighter"><%= val %></h1>
                    <a href="/files/<%= val %>"  class="text-blue-500 hover:underline">Read More</a>
                </div>
            <% }) %>
            <div class="task hidden w-72 px-3 py-4 bg-zinc-800 text-white rounded-lg">
                <h1 class="text-white text-3xl tracking-tighter">Task One</h1>
                <a href="/files/<%=  %>" class="text-blue-500 hover:underline">Read More</a>
            </div>

            <div class="task hidden w-72 px-3 py-4 bg-zinc-800 text-white rounded-lg">
                <h1 class="text-white text-3xl tracking-tighter">Task Two</h1>
                <a href="#" class="text-blue-500 hover:underline">Read More</a>
            </div>

            <div class="task hidden w-72 px-3 py-4 bg-zinc-800 text-white rounded-lg">
                <h1 class="text-white text-3xl tracking-tighter">Task Three</h1>
                <a href="#" class="text-blue-500 hover:underline">Read More</a>
            </div>
            <div class="task hidden w-72 px-3 py-4 bg-zinc-800 text-white rounded-lg">
                <h1 class="text-white text-3xl tracking-tighter">Task Four</h1>
                <a href="#" class="text-blue-500 hover:underline">Read More</a>
            </div>

        </div>
    </div>
</body>
</html>